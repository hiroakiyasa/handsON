<mxfile host="app.diagrams.net" modified="2026-05-04T00:00:00.000Z" agent="GitHub Copilot" version="24.7.17">
	<diagram id="ai-history-timeline" name="AI History">
		<mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1400" math="0" shadow="0">
			<root>
				<mxCell id="0" />
				<mxCell id="1" parent="0" />
				<mxCell id="bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#d7e3f4;arcSize=24;" vertex="1" parent="1">
					<mxGeometry x="20" y="20" width="2360" height="1360" as="geometry" />
				</mxCell>
				<mxCell id="title" value="AIの歴史&#xa;理論的基盤から生成AIまでの発展" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=28;fontStyle=1;fontColor=#0f172a;whiteSpace=wrap;" vertex="1" parent="1">
					<mxGeometry x="60" y="40" width="700" height="80" as="geometry" />
				</mxCell>
				<mxCell id="subtitle" value="AIは、理論・計算資源・データ・社会需要の積み重ねによって、ブームと停滞を繰り返しながら進化してきた。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=14;fontColor=#475569;whiteSpace=wrap;" vertex="1" parent="1">
					<mxGeometry x="60" y="112" width="980" height="40" as="geometry" />
				</mxCell>
				<mxCell id="legend1" value="青: 理論と誕生" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#93c5fd;fontSize=12;fontColor=#1e3a8a;spacing=8;" vertex="1" parent="1">
					<mxGeometry x="1720" y="46" width="160" height="32" as="geometry" />
				</mxCell>
				<mxCell id="legend2" value="橙: 冬と停滞" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#fdba74;fontSize=12;fontColor=#9a3412;spacing=8;" vertex="1" parent="1">
					<mxGeometry x="1890" y="46" width="160" height="32" as="geometry" />
				</mxCell>
				<mxCell id="legend3" value="緑: 実用化と拡大" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#86efac;fontSize=12;fontColor=#166534;spacing=8;" vertex="1" parent="1">
					<mxGeometry x="2060" y="46" width="160" height="32" as="geometry" />
				</mxCell>
				<mxCell id="timeline" value="" style="endArrow=none;html=1;rounded=0;strokeColor=#334155;strokeWidth=4;" edge="1" parent="1" source="node1" target="node7">
					<mxGeometry relative="1" as="geometry" />
				</mxCell>

				<mxCell id="card1" value="&lt;b&gt;1. AI誕生以前の理論的基盤&lt;/b&gt;&lt;br&gt;20世紀前半から1950年ごろ&lt;br&gt;&lt;br&gt;・計算理論の発展&lt;br&gt;・チューリングテスト&lt;br&gt;・人工ニューロンの概念" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#60a5fa;fontSize=16;fontColor=#0f172a;align=left;verticalAlign=top;spacing=12;arcSize=20;" vertex="1" parent="1">
					<mxGeometry x="70" y="230" width="270" height="180" as="geometry" />
				</mxCell>
				<mxCell id="node1" value="1943-1950" style="ellipse;whiteSpace=wrap;html=1;fillColor=#2563eb;strokeColor=#1d4ed8;fontSize=13;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
					<mxGeometry x="165" y="640" width="90" height="90" as="geometry" />
				</mxCell>
				<mxCell id="edge1" value="" style="endArrow=none;html=1;rounded=0;strokeColor=#60a5fa;strokeWidth=2;dashed=1;" edge="1" parent="1" source="card1" target="node1">
					<mxGeometry relative="1" as="geometry" />
				</mxCell>
				<mxCell id="milestone1" value="1950&#xa;チューリングテスト" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#93c5fd;fontSize=12;fontColor=#1e3a8a;spacing=8;" vertex="1" parent="1">
					<mxGeometry x="90" y="435" width="230" height="64" as="geometry" />
				</mxCell>

				<mxCell id="card2" value="&lt;b&gt;2. AIの誕生と第一次ブーム&lt;/b&gt;&lt;br&gt;1950年代-1960年代前半&lt;br&gt;&lt;br&gt;・ダートマス会議&lt;br&gt;・記号処理、推論、探索&lt;br&gt;・Logic Theorist / GPS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#3b82f6;fontSize=16;fontColor=#0f172a;align=left;verticalAlign=top;spacing=12;arcSize=20;" vertex="1" parent="1">
					<mxGeometry x="390" y="160" width="290" height="200" as="geometry" />
				</mxCell>
				<mxCell id="node2" value="1956" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1d4ed8;strokeColor=#1e40af;fontSize=18;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
					<mxGeometry x="495" y="640" width="90" height="90" as="geometry" />
				</mxCell>
				<mxCell id="edge2" value="" style="endArrow=none;html=1;rounded=0;strokeColor=#3b82f6;strokeWidth=2;dashed=1;" edge="1" parent="1" source="card2" target="node2">
					<mxGeometry relative="1" as="geometry" />
				</mxCell>
				<mxCell id="milestone2" value="1956&#xa;ダートマス会議で&#xa;Artificial Intelligence が定着" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#60a5fa;fontSize=12;fontColor=#1e3a8a;spacing=8;" vertex="1" parent="1">
					<mxGeometry x="420" y="390" width="230" height="84" as="geometry" />
				</mxCell>

				<mxCell id="card3" value="&lt;b&gt;3. 限界の露呈とAIの冬&lt;/b&gt;&lt;br&gt;1960年代後半-1970年代&lt;br&gt;&lt;br&gt;・現実世界の複雑さに対応困難&lt;br&gt;・探索空間の爆発&lt;br&gt;・単層パーセプトロンの限界" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#fb923c;fontSize=16;fontColor=#7c2d12;align=left;verticalAlign=top;spacing=12;arcSize=20;" vertex="1" parent="1">
					<mxGeometry x="720" y="230" width="310" height="190" as="geometry" />
				</mxCell>
				<mxCell id="node3" value="1969-1970s" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ea580c;strokeColor=#c2410c;fontSize=13;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
					<mxGeometry x="830" y="640" width="95" height="95" as="geometry" />
				</mxCell>
				<mxCell id="edge3" value="" style="endArrow=none;html=1;rounded=0;strokeColor=#fb923c;strokeWidth=2;dashed=1;" edge="1" parent="1" source="card3" target="node3">
					<mxGeometry relative="1" as="geometry" />
				</mxCell>
				<mxCell id="milestone3" value="1969&#xa;ミンスキーとパパートが&#xa;パーセプトロンの限界を指摘" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fdba74;fontSize=12;fontColor=#9a3412;spacing=8;" vertex="1" parent="1">
					<mxGeometry x="760" y="445" width="230" height="84" as="geometry" />
				</mxCell>

				<mxCell id="card4" value="&lt;b&gt;4. エキスパートシステムと第二次ブーム&lt;/b&gt;&lt;br&gt;1980年代&lt;br&gt;&lt;br&gt;・専門知識をルール化&lt;br&gt;・MYCIN などが実務で注目&lt;br&gt;・知識獲得の難しさが制約" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#4ade80;fontSize=16;fontColor=#14532d;align=left;verticalAlign=top;spacing=12;arcSize=20;" vertex="1" parent="1">
					<mxGeometry x="1060" y="160" width="320" height="200" as="geometry" />
				</mxCell>
				<mxCell id="node4" value="1980s" style="ellipse;whiteSpace=wrap;html=1;fillColor=#16a34a;strokeColor=#15803d;fontSize=16;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
					<mxGeometry x="1178" y="640" width="90" height="90" as="geometry" />
				</mxCell>
				<mxCell id="edge4" value="" style="endArrow=none;html=1;rounded=0;strokeColor=#4ade80;strokeWidth=2;dashed=1;" edge="1" parent="1" source="card4" target="node4">
					<mxGeometry relative="1" as="geometry" />
				</mxCell>
				<mxCell id="milestone4" value="代表例: MYCIN&#xa;限定領域では専門家級の判断" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#86efac;fontSize=12;fontColor=#166534;spacing=8;" vertex="1" parent="1">
					<mxGeometry x="1100" y="390" width="240" height="70" as="geometry" />
				</mxCell>

				<mxCell id="card5" value="&lt;b&gt;5. 機械学習への転換&lt;/b&gt;&lt;br&gt;1990年代-2000年代前半&lt;br&gt;&lt;br&gt;・ルールベースからデータ駆動へ&lt;br&gt;・決定木、ベイズ、SVM、HMM&lt;br&gt;・認識・検索・推薦の精度向上" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#22c55e;fontSize=16;fontColor=#14532d;align=left;verticalAlign=top;spacing=12;arcSize=20;" vertex="1" parent="1">
					<mxGeometry x="1420" y="230" width="320" height="200" as="geometry" />
				</mxCell>
				<mxCell id="node5" value="1997" style="ellipse;whiteSpace=wrap;html=1;fillColor=#15803d;strokeColor=#166534;fontSize=18;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
					<mxGeometry x="1535" y="640" width="90" height="90" as="geometry" />
				</mxCell>
				<mxCell id="edge5" value="" style="endArrow=none;html=1;rounded=0;strokeColor=#22c55e;strokeWidth=2;dashed=1;" edge="1" parent="1" source="card5" target="node5">
					<mxGeometry relative="1" as="geometry" />
				</mxCell>
				<mxCell id="milestone5" value="1997&#xa;Deep Blue がカスパロフに勝利" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#86efac;fontSize=12;fontColor=#166534;spacing=8;" vertex="1" parent="1">
					<mxGeometry x="1460" y="455" width="240" height="64" as="geometry" />
				</mxCell>

				<mxCell id="card6" value="&lt;b&gt;6. ディープラーニングによる第三次ブーム&lt;/b&gt;&lt;br&gt;2010年代&lt;br&gt;&lt;br&gt;・大規模データ + GPU + 学習法改良&lt;br&gt;・画像、音声、自然言語で飛躍&lt;br&gt;・直感型とされた課題にも進出" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#38bdf8;fontSize=16;fontColor=#0f172a;align=left;verticalAlign=top;spacing=12;arcSize=20;" vertex="1" parent="1">
					<mxGeometry x="1770" y="160" width="340" height="210" as="geometry" />
				</mxCell>
				<mxCell id="node6" value="2012-2016" style="ellipse;whiteSpace=wrap;html=1;fillColor=#0284c7;strokeColor=#0369a1;fontSize=14;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
					<mxGeometry x="1900" y="638" width="96" height="96" as="geometry" />
				</mxCell>
				<mxCell id="edge6" value="" style="endArrow=none;html=1;rounded=0;strokeColor=#38bdf8;strokeWidth=2;dashed=1;" edge="1" parent="1" source="card6" target="node6">
					<mxGeometry relative="1" as="geometry" />
				</mxCell>
				<mxCell id="milestone6a" value="2012&#xa;ImageNet で深層学習が躍進" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f9ff;strokeColor=#7dd3fc;fontSize=12;fontColor=#075985;spacing=8;" vertex="1" parent="1">
					<mxGeometry x="1790" y="395" width="155" height="74" as="geometry" />
				</mxCell>
				<mxCell id="milestone6b" value="2016&#xa;AlphaGo がトップ棋士に勝利" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f9ff;strokeColor=#7dd3fc;fontSize=12;fontColor=#075985;spacing=8;" vertex="1" parent="1">
					<mxGeometry x="1955" y="395" width="155" height="74" as="geometry" />
				</mxCell>

				<mxCell id="card7" value="&lt;b&gt;7. 生成AIの拡大と社会実装&lt;/b&gt;&lt;br&gt;2020年代&lt;br&gt;&lt;br&gt;・LLM、要約、翻訳、対話、コード生成&lt;br&gt;・画像、音声、動画までマルチモーダル化&lt;br&gt;・倫理、法制度、雇用、偽情報が主要論点" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#34d399;fontSize=16;fontColor=#14532d;align=left;verticalAlign=top;spacing=12;arcSize=20;" vertex="1" parent="1">
					<mxGeometry x="2140" y="230" width="200" height="220" as="geometry" />
				</mxCell>
				<mxCell id="node7" value="2020s" style="ellipse;whiteSpace=wrap;html=1;fillColor=#059669;strokeColor=#047857;fontSize=16;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
					<mxGeometry x="2195" y="640" width="90" height="90" as="geometry" />
				</mxCell>
				<mxCell id="edge7" value="" style="endArrow=none;html=1;rounded=0;strokeColor=#34d399;strokeWidth=2;dashed=1;" edge="1" parent="1" source="card7" target="node7">
					<mxGeometry relative="1" as="geometry" />
				</mxCell>
				<mxCell id="milestone7" value="基盤技術: Transformer / 大規模事前学習 / クラウド計算基盤" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#86efac;fontSize=12;fontColor=#166534;spacing=8;" vertex="1" parent="1">
					<mxGeometry x="2145" y="475" width="190" height="84" as="geometry" />
				</mxCell>

				<mxCell id="cycle" value="AI史の反復パターン&#xa;期待の高まり → 技術的限界の露呈 → 停滞 → 新手法と環境整備で再加速" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e2e8f0;strokeColor=#94a3b8;fontSize=18;fontStyle=1;fontColor=#0f172a;align=center;verticalAlign=middle;spacing=14;arcSize=20;" vertex="1" parent="1">
					<mxGeometry x="680" y="800" width="1040" height="90" as="geometry" />
				</mxCell>

				<mxCell id="insightHeader" value="AIの歴史から見える3つの特徴" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=22;fontStyle=1;fontColor=#0f172a;whiteSpace=wrap;" vertex="1" parent="1">
					<mxGeometry x="70" y="960" width="420" height="36" as="geometry" />
				</mxCell>
				<mxCell id="insight1" value="1. ブームと冬の循環&#xa;過度な期待の後に限界が明らかになり、研究投資が縮小する流れが繰り返された。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cbd5e1;fontSize=14;fontColor=#334155;align=left;verticalAlign=top;spacing=12;arcSize=18;" vertex="1" parent="1">
					<mxGeometry x="70" y="1010" width="710" height="110" as="geometry" />
				</mxCell>
				<mxCell id="insight2" value="2. 単独技術ではなく条件の組み合わせ&#xa;理論、計算資源、データ、社会的需要がそろって初めて大きな実用化が進んだ。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cbd5e1;fontSize=14;fontColor=#334155;align=left;verticalAlign=top;spacing=12;arcSize=18;" vertex="1" parent="1">
					<mxGeometry x="835" y="1010" width="710" height="110" as="geometry" />
				</mxCell>
				<mxCell id="insight3" value="3. 模倣から協働へ&#xa;人間の知能を再現する発想から、特定課題の高性能化を経て、人間の判断や創造を支援・拡張する方向へ広がった。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cbd5e1;fontSize=14;fontColor=#334155;align=left;verticalAlign=top;spacing=12;arcSize=18;" vertex="1" parent="1">
					<mxGeometry x="1600" y="1010" width="710" height="110" as="geometry" />
				</mxCell>

				<mxCell id="closing" value="今後の論点&#xa;安全性・公平性・透明性・著作権・個人情報保護・雇用影響など、AIは技術史であると同時に社会制度の歴史でもある。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0f172a;strokeColor=#1e293b;fontSize=16;fontColor=#f8fafc;align=left;verticalAlign=middle;spacing=14;arcSize=22;" vertex="1" parent="1">
					<mxGeometry x="70" y="1180" width="2240" height="110" as="geometry" />
				</mxCell>
			</root>
		</mxGraphModel>
	</diagram>
</mxfile>
